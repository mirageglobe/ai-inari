Output demo.gif

Set FontSize 18
Set Width 1000
Set Height 600
Set Padding 10
Set WindowBar Colorful
Set Theme "Dracula"

# Start Kitsune
Type "./bin/kitsune"
Enter
Sleep 2s

# Navigate to a session
Type "jj"
Sleep 500ms

# Open chat
Type "c"
Sleep 1s
Type "hello kitsune!"
Enter
Sleep 8s

# Exit chat
Escape
Sleep 1s

# Add a new kitsune
Type "s"
Sleep 500ms
Type "vhs-kitsune"
Enter
Sleep 1s

# Apply a model
Type "m"
Sleep 1s
Enter
Sleep 1s

# Quit
Type "q"
